{
  "default_agent": "main",
  "discovery": {
    "include_global_user_resources": true,
    "include_external_ecosystems": false,
    "allow_remote": false,
    "trust_store_dir": ".agentsdk"
  },
  "model_policy": {
    "use_case": "agentic_coding",
    "source_api": "auto"
  },
  "sources": [
    "resources/.agents"
  ],
  "plugins": [
    {"name": "browser"}
  ]
}
